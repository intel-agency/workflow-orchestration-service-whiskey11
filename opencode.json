    "openai": {
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4",
          "limit": {
            "context": 1050000,
            "output": 128000
          }
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 Mini",
          "limit": {
            "context": 400000,
            "output": 128000
          }
        },
        "gpt-5.4-nano": {
          "name": "GPT-5.4 Nano",
          "limit": {
            "context": 400000,
            "output": 128000
          }
        },
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "limit": {
            "context": 400000,
            "output": 128000
          }
        }
      }
    },
    "kimi-for-coding": {
      "models": {
        "kimi-k2-thinking": {
          "name": "Kimi K2 Thinking",
          "limit": {
            "context": 262144,
            "output": 32768
          }
        },
        "k2p5": {
          "name": "Kimi K2.5",
          "limit": {
            "context": 262144,
            "output": 32768
          }
        }
      }
    },
    "google": {
      "options": {
        "projectId": "gemini-code-assist-490720"
      },
      "models": {
        "gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro (Preview)",
          "limit": {
            "context": 2097152,
            "output": 65536
          }
        },
        "gemini-3.1-flash-lite-preview": {
          "name": "Gemini 3.1 Flash Lite (Preview)",
          "limit": {
            "context": 1048576,
            "output": 65536
          }
        },
        "gemini-3-pro-preview": {
          "name": "Gemini 3.0 Pro (Preview)",
          "limit": {
            "context": 2097152,
            "output": 65536
          }
        },
        "gemini-3-flash-preview": {
          "name": "Gemini 3.0 Flash (Preview)",
          "limit": {
            "context": 1048576,
            "output": 65536
          }
        }
      }
    }
  },
  "model": "zai-coding-plan/glm-5.1",
  "small_model": "zai-coding-plan/glm-5-turbo",
  "permission": {
    "external_directory": {
      "/tmp/*": "allow"
    },
    "mcp_tool": {
      "sequential-thinking:sequentialthinking": "allow",
      "memory:create_entities": "allow",
      "memory:create_relations": "allow",
      "memory:add_observations": "allow",
      "memory:delete_entities": "allow",
      "memory:delete_observations": "allow",
      "memory:delete_relations": "allow",
      "memory:read_graph": "allow",
      "memory:search_nodes": "allow",
      "memory:open_nodes": "allow"
    }
  },
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "environment": {
        "MEMORY_FILE_PATH": "${MEMORY_FILE_PATH}"
      }
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GH_ORCHESTRATION_AGENT_TOKEN}"
      },
      "enabled": false
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": false
    }
  }
}